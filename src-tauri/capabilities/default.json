{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability set for the DDPEC main + dropdown windows. Grants the minimum needed for tray, autostart, shell.open (BlackHole download / macOS Sound prefs deep-link), and event-based dropdown↔main coordination.",
  "windows": ["main", "dropdown"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:webview:default",
    "core:window:default",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-set-focus",
    "core:window:allow-set-position",
    "core:tray:default",
    "shell:allow-open",
    "autostart:default",
    "autostart:allow-enable",
    "autostart:allow-disable",
    "autostart:allow-is-enabled"
  ]
}
